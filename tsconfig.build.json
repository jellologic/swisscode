{
  // Emit config: src/ -> dist/ as plain JavaScript.
  //
  // Constraint 6: the PUBLISHED artifact is compiled JS. Nothing shipped
  // depends on Node's native type stripping, which is not reliably enabled
  // across the whole ">=22" engines range.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "rootDir": "src",
    "outDir": "dist",

    // No .d.ts: this is a CLI, not a library. Nothing imports it as a package.
    "declaration": false,

    // No source maps either. They would reference .ts files that the tarball
    // deliberately does not ship, leaving dangling links in the artifact.
    // Dev debugging reads the real sources, because dev runs the real sources.
    "sourceMap": false
  },

  // The Ink UI is NOT emitted by tsc. esbuild bundles it straight from source
  // into dist/ui.js (see build.js); emitting it here as well would ship two
  // copies of the same component tree and put React-importing modules inside
  // the package next to a launch path that promises never to touch them.
  //
  // The exclude also follows the wizard's NON-.tsx imports — the catalog / net /
  // clock / cache leaf cluster and the two core helpers (catalog, format) it
  // pulls in. Those are reached ONLY by the UI (verified: no launch/config/doctor
  // runtime module imports them), and esbuild already inlines them into dist/ui.js,
  // so emitting them here would ship that cluster twice. fs-config-store stays
  // emitted — it is the CONFIG store the launch/config paths need, distinct from
  // the UI-only fs-cache-store.
  "include": ["src"],
  "exclude": [
    "src/adapters/ui",
    "src/composition/ui-root.ts",
    "src/core/catalog.ts",
    "src/core/format.ts",
    "src/adapters/net",
    "src/adapters/clock",
    "src/adapters/store/fs-cache-store.ts",
    "src/adapters/catalog"
  ]
}
